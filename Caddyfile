# Caddy s'occupe TOUT SEUL du certificat HTTPS (Let's Encrypt) dès que le
# DNS de myplaylog.cc pointe vers l'IP du VPS. Le www redirige vers l'apex.

www.myplaylog.cc {
    redir https://myplaylog.cc{uri} permanent
}

myplaylog.cc {
    # Compression partout SAUF sur le flux temps réel du chat : un flux SSE ne
    # se termine jamais, et le compresseur peut retenir les évènements dans son
    # tampon — les messages arriveraient par paquets, avec des secondes de
    # retard. Le reste du site reste compressé normalement.
    @compressible not path /api/chat/stream
    encode @compressible gzip zstd

    # L'API et les fichiers uploadés vont vers le backend Express.
    @backend path /api/* /uploads/*
    handle @backend {
        reverse_proxy server:4000
    }

    # Robots sociaux (aperçus de partage) sur les pages partageables : le
    # backend renvoie des balises Open Graph dynamiques (titre, image, infos).
    # Ces robots ne lisent que le <head> et n'exécutent pas de JS -> sans ça,
    # ils ne voient que les méta génériques de la SPA. Les vraies personnes
    # (autres User-Agent) tombent dans le `handle` suivant et reçoivent la SPA.
    @crawler {
        path /lists/* /u/* /game/* /clip/*
        header_regexp User-Agent (?i)(facebookexternalhit|facebot|WhatsApp|Twitterbot|Discordbot|TelegramBot|Slackbot|LinkedInBot|redditbot|Pinterest|SkypeUriPreview|vkShare|Embedly|Iframely|Googlebot|bingbot|Applebot|ia_archiver|Google-InspectionTool)
    }
    handle @crawler {
        reverse_proxy server:4000
    }

    # Tout le reste : les fichiers statiques du build React (SPA).
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
